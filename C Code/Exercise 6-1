#include <iostream>
#include <iomanip>
#include <string>
#include <cctype>

using namespace std;

bool isPalindrome(string str) {
int length = str.length(); 
for (int i = 0; i < length / 2; i++) {
    if (toupper(str[i]) != toupper(str[length - 1 - i])) {
         return false;
    }  // if    
  } // for loop
 return true;
}// isPalindrome

