#include <iostream>
#include <cctype>
using namespace std;

int main() {
    const int SIZE = 100;
    char text[SIZE];

    cout << "Enter a string: ";
    cin.getline(text, SIZE);

    for (int i = 0; text[i] != '\0'; i++) {
        text[i] = toupper(text[i]);
    }

    cout << "Uppercase: " << text << endl;

    return 0;
}
