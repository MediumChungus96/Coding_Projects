#include <iostream>

using namespace std;

int main() {
    int num1, num2;
    int small, large;
    int countBy3 = 0;
    int countBy5 = 0;
        
    cout << "Please input two integers seperated by a space: ";
    cin >> num1 >> num2;
    
    if (num1 <= num2) {
        small = num1;
        large = num2;
    } else {
        small = num2;
        large = num1;
    }

    for (int i = small; i <= large; i++) {
        if (i % 3 == 0) {
            countBy3++;
        }
        if (i % 5 == 0) {
            countBy5++;
        }
    }

    cout << "Multiples of 3: " << countBy3 << endl;
    cout << "Multiples of 5: " << countBy5 << endl;
    
    return 0;
}
