#include <iostream>
#include <string>
#include <iomanip>
#include <cmath>

using namespace std;

int main() {
    char letter;
    char digit = '0';
    int letterCount = 0;
    char response;
    string result;

    cout << "Enter Y/y to convert a telephone number from" << endl;
    cout << "letters to digits." << endl;
    cout << "Enter any other letter to terminate the program." << endl;
    cin >> response;
    cin.ignore();

    while (toupper(response) == 'Y') {
        letterCount = 0;
        result = "";
        cout << "Enter a telephone number using letters: ";

        while (cin.get(letter) && letter != '\n') {
            if (letterCount < 7 && isalpha(letter)) {
                switch (toupper(letter)) {
                    case 'A': case 'B': case 'C':
                        digit = '2';
                        break;
                    case 'D': case 'E': case 'F':
                        digit = '3';
                        break;
                    case 'G': case 'H': case 'I':
                        digit = '4';
                        break;
                    case 'J': case 'K': case 'L':
                        digit = '5';
                        break;
                    case 'M': case 'N': case 'O':
                        digit = '6';
                        break;
                    case 'P': case 'Q': case 'R': case 'S':
                        digit = '7';
                        break;
                    case 'T': case 'U': case 'V':
                        digit = '8';
                        break;
                    case 'W': case 'X': case 'Y': case 'Z':
                        digit = '9';
                        break;
                }
                result += digit;
                letterCount++;
                if (letterCount == 3) {
                    result += '-';
                }
            }
        }

        cout << endl;
        cout << "The corresponding telephone number is:" << endl;
        cout << result << endl;

        cout << "To process another telephone number, enter Y/y" << endl;
        cout << "Enter any other letter to terminate the program." << endl;
        cin >> response;
        cin.ignore();
    }

    return 0;
}
