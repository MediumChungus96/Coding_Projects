        royalty3 = (copiesSold * netPrice) * royaltyRates::rate3one ;
    } else {
        royalty3 = ((royaltyRates::rate3one * netPrice) * royaltyRates::threshold) + (royaltyRates::rate3two * netPrice * (copiesSold - royaltyRates::threshold));
    }

